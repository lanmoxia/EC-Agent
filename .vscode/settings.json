{
  // —— VSCode 内看前端：真全自动 ——
  // 主力机制在 .vscode/tasks.json（folderOpen 自动任务）：打开/重载项目时
  // 自动起前端 dev server，ready 后用内置浏览器自动打开 http://localhost:5173。
  // 下面这条让首次打开的「Allow and run」授权尽量免掉（若机器策略不认会被忽略，
  // 首次手动点一次 Allow 即可）。
  "task.allowAutomaticTasks": "on",

  // 辅助：点任意 localhost 链接(终端/聊天)时走 VSCode 内置浏览器，而非外部 Chrome。
  // 注意：这个开关只改「点击」行为，不会自己弹页面——自动弹靠上面的 tasks.json。
  "workbench.browser.openLocalhostLinks": true
}
